:root {
  --blue: #1A56DB; --blue-light: #DBEAFE; --blue-dark: #1E40AF;
  --red: #DC2626; --red-light: #FEE2E2;
  --green: #16A34A; --green-light: #DCFCE7;
  --yellow-bg: #FFFBEB; --yellow-border: #F59E0B;
  --cyan: #0D9488; --cyan-light: #CCFBF1;
  --bg: #F8FAFC; --card: #FFFFFF; --text: #0F172A; --text-secondary: #64748B;
  --border: #E2E8F0;
  --radius: 12px; --radius-sm: 8px;
  --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
  --shadow-md: 0 4px 6px rgba(0,0,0,0.05), 0 2px 4px rgba(0,0,0,0.04);
  --sidebar-width: 240px;
}
* { margin:0; padding:0; box-sizing:border-box; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  background: #F1F5F9; color: var(--text); line-height: 1.6; min-height: 100vh;
}
.app-layout { display: flex; min-height: 100vh; }

/* Sidebar */
.sidebar {
  width: var(--sidebar-width); background: #fff; border-right: 1px solid var(--border);
  display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 100;
  box-shadow: 2px 0 8px rgba(0,0,0,0.03);
}
.sidebar-logo {
  padding: 20px 20px 16px; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 10px; cursor: pointer;
}
.sidebar-logo .logo-icon { font-size: 28px; }
.sidebar-logo .logo-text { font-size: 18px; font-weight: 700; color: var(--blue); }
.sidebar-logo .logo-sub { font-size: 11px; color: var(--text-secondary); }
.sidebar-nav { flex: 1; padding: 8px 0; overflow-y: auto; }
.nav-section { padding: 12px 20px 4px; font-size: 11px; font-weight: 600; color: #94A3B8; text-transform: uppercase; letter-spacing: 1px; }
.nav-link {
  display: flex; align-items: center; gap: 10px; padding: 10px 20px; width: 100%;
  font-size: 14px; color: var(--text-secondary); cursor: pointer;
  transition: all 0.15s; border: none; background: none; text-align: left;
  border-left: 3px solid transparent;
}
.nav-link:hover { background: var(--bg); color: var(--text); }
.nav-link.active { background: var(--blue-light); color: var(--blue); font-weight: 600; border-left-color: var(--blue); }
.nav-link .nav-icon { font-size: 18px; width: 24px; text-align: center; }
.nav-link .nav-badge { margin-left: auto; background: var(--blue); color: #fff; border-radius: 10px; padding: 1px 7px; font-size: 10px; font-weight: 600; }
.sidebar-footer { padding: 12px 20px; border-top: 1px solid var(--border); font-size: 12px; color: var(--text-secondary); }
.sidebar-footer .hotline { color: var(--red); font-weight: 700; font-size: 16px; margin-top: 2px; cursor: pointer; }

/* Main */
.main-content { margin-left: var(--sidebar-width); flex: 1; min-width: 0; }
.top-bar {
  background: #fff; border-bottom: 1px solid var(--border);
  padding: 12px 24px; display: flex; align-items: center; justify-content: space-between; gap: 16px;
  position: sticky; top: 0; z-index: 50;
}
.search-box {
  flex: 1; max-width: 560px; display: flex; align-items: center;
  background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius);
  padding: 10px 14px; gap: 8px; transition: border-color 0.2s;
}
.search-box:focus-within { border-color: var(--blue); box-shadow: 0 0 0 3px var(--blue-light); }
.search-box input { flex: 1; border: none; outline: none; background: transparent; font-size: 14px; color: var(--text); }
.search-box input::placeholder { color: #94A3B8; }
.search-hint { font-size: 11px; color: #94A3B8; background: var(--border); border-radius: 4px; padding: 2px 6px; white-space: nowrap; }
.top-actions { display: flex; gap: 8px; }
.top-actions button { background: none; border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 6px 14px; font-size: 13px; cursor: pointer; color: var(--text-secondary); transition: all 0.15s; }
.top-actions button:hover { background: var(--bg); color: var(--text); }
.btn-elders { border-color: var(--red) !important; color: var(--red) !important; }
.btn-elders:hover, .btn-elders.active { background: var(--red-light) !important; }

/* Pages */
.page { display: none; padding: 24px; max-width: 1200px; }
.page.active { display: block; }
.page-title-area { margin-bottom: 24px; }
.page-title-area h1 { font-size: 24px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
.page-title-area p { font-size: 14px; color: var(--text-secondary); }
.loading { text-align: center; color: var(--text-secondary); padding: 60px 20px; font-size: 14px; }

/* Grids */
.grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
.grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }

/* Cards */
.card {
  background: var(--card); border-radius: var(--radius);
  padding: 20px; box-shadow: var(--shadow); border: 1px solid var(--border);
  transition: box-shadow 0.2s, transform 0.15s; cursor: pointer;
}
.card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
.card-title { font-size: 16px; font-weight: 600; margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }
.card-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.6; }

.tag {
  display: inline-block; padding: 2px 8px; border-radius: 4px;
  font-size: 11px; font-weight: 500; margin-right: 4px;
}
.tag-red { background: var(--red-light); color: var(--red); }
.tag-blue { background: var(--blue-light); color: var(--blue); }
.tag-green { background: var(--green-light); color: var(--green); }
.tag-gray { background: #F1F5F9; color: var(--text-secondary); }
.tag-cyan { background: var(--cyan-light); color: #0F766E; }

/* Hero */
.hero {
  background: linear-gradient(135deg, #1E3A5F 0%, #1A56DB 50%, #2563EB 100%);
  border-radius: 16px; padding: 40px; color: #fff; margin-bottom: 24px;
  position: relative; overflow: hidden;
}
.hero::after { content: "⚖️"; position: absolute; right: -20px; top: -20px; font-size: 180px; opacity: 0.08; }
.hero h1 { font-size: 28px; font-weight: 700; margin-bottom: 8px; position: relative; z-index: 1; }
.hero p { font-size: 15px; opacity: 0.85; max-width: 500px; margin-bottom: 16px; position: relative; z-index: 1; }
.hero-search {
  display: flex; align-items: center; background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.25); border-radius: var(--radius);
  padding: 12px 16px; max-width: 500px; gap: 8px; position: relative; z-index: 1;
  backdrop-filter: blur(10px);
}
.hero-search input { flex: 1; border: none; outline: none; background: transparent; font-size: 15px; color: #fff; }
.hero-search input::placeholder { color: rgba(255,255,255,0.5); }
.hero-stats { display: flex; gap: 32px; margin-top: 20px; position: relative; z-index: 1; }
.hero-stat { text-align: center; }
.hero-stat .num { font-size: 24px; font-weight: 700; }
.hero-stat .label { font-size: 12px; opacity: 0.7; }

/* AI Card */
.ai-card {
  background: linear-gradient(135deg, #EFF6FF, #DBEAFE); border: 1px solid #BFDBFE;
  border-radius: var(--radius); padding: 24px; cursor: pointer; transition: all 0.2s;
}
.ai-card:hover { box-shadow: var(--shadow-md); border-color: var(--blue); }
.ai-card .ai-header { display: flex; align-items: center; gap: 12px; font-size: 36px; margin-bottom: 12px; }
.ai-card .ai-header .ai-title { font-size: 18px; font-weight: 700; color: var(--blue-dark); }
.ai-card .ai-desc { font-size: 14px; color: var(--text-secondary); }
.ai-card .ai-examples { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
.ai-example {
  background: #fff; border: 1px solid var(--border); border-radius: 20px;
  padding: 6px 14px; font-size: 12px; color: var(--text-secondary); cursor: pointer;
  transition: all 0.15s;
}
.ai-example:hover { border-color: var(--blue); color: var(--blue); background: var(--blue-light); }

.btn-secondary {
  background: #fff; color: var(--blue); border: 1.5px solid var(--blue);
  border-radius: var(--radius); padding: 10px 20px;
  font-size: 14px; font-weight: 500; cursor: pointer; display: inline-block;
}
.btn-secondary:hover { background: var(--blue-light); }

/* Category */
.category-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 12px; }
.cat-item { font-size: 12px; text-align: center; padding: 8px; border-radius: var(--radius-sm); background: var(--bg); cursor: pointer; transition: all 0.15s; }
.cat-item:hover { background: var(--blue-light); color: var(--blue); }

/* Section */
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; margin-top: 8px; }
.section-header h2 { font-size: 18px; font-weight: 700; }

/* Scene Card */
.scene-card {
  background: var(--card); border-radius: var(--radius); padding: 20px;
  box-shadow: var(--shadow); border: 1px solid var(--border);
  cursor: pointer; transition: all 0.2s;
}
.scene-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
.scene-card .s-title { font-size: 16px; font-weight: 600; margin-bottom: 8px; }
.scene-card .s-conclusion { padding: 8px 12px; border-radius: 6px; margin-bottom: 8px; font-size: 13px; font-weight: 600; }
.s-conclusion.good { background: var(--green-light); color: #166534; }
.s-conclusion.warn { background: var(--yellow-bg); color: #92400E; }
.s-conclusion.bad { background: var(--red-light); color: #991B1B; }
.scene-card .s-desc { font-size: 13px; color: var(--text-secondary); }

/* Tool mini */
.tool-mini { text-align: center; padding: 24px 16px; }
.tool-mini .t-icon { font-size: 36px; }
.tool-mini .t-label { font-weight: 600; margin-top: 8px; font-size: 14px; }

/* Values */
.values-section { margin-bottom: 32px; }
.values-section h3 { font-size: 13px; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 2px solid var(--border); }
.value-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
.value-card {
  background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);
  padding: 20px 16px; text-align: center; cursor: pointer; transition: all 0.2s;
}
.value-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
.value-card .v-icon { font-size: 32px; margin-bottom: 8px; }
.value-card .v-name { font-size: 16px; font-weight: 700; margin-bottom: 2px; }
.value-card .v-count { font-size: 12px; color: var(--text-secondary); }
.value-card.national { border-top: 3px solid var(--red); }
.value-card.social { border-top: 3px solid var(--blue); }
.value-card.personal { border-top: 3px solid var(--green); }

/* Scene Detail */
.back-link { margin-bottom: 16px; }
.back-link a { color: var(--blue); font-size: 14px; text-decoration: none; }
.scene-header { margin-bottom: 24px; }
.scene-header h1 { font-size: 26px; font-weight: 700; }
.scene-meta { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; }
.conclusion-box {
  border-radius: var(--radius); padding: 20px; margin-bottom: 20px;
  font-size: 16px; font-weight: 600;
}
.conclusion-box.good { background: var(--green-light); color: #166534; border: 1px solid #86EFAC; }
.conclusion-box.warn { background: var(--yellow-bg); color: #92400E; border: 1px solid var(--yellow-border); }
.conclusion-box.bad { background: var(--red-light); color: #991B1B; border: 1px solid #FCA5A5); }

.detail-grid { display: grid; grid-template-columns: 1fr 360px; gap: 24px; }
.detail-main .section { margin-bottom: 24px; }
.detail-main .section h3 { font-size: 16px; font-weight: 700; margin-bottom: 12px; }
.step-list { list-style: none; }
.step-list li {
  padding: 12px 0; border-bottom: 1px solid var(--border);
  display: flex; align-items: flex-start; gap: 12px; font-size: 14px;
}
.step-list li:last-child { border-bottom: none; }
.step-num {
  width: 28px; height: 28px; background: var(--blue); color: #fff;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 700; flex-shrink: 0;
}
.warning-box {
  background: var(--yellow-bg); border: 1px solid var(--yellow-border);
  border-radius: var(--radius-sm); padding: 14px; margin-bottom: 16px;
  font-size: 13px; color: #92400E; line-height: 1.8;
}

.detail-sidebar .side-card {
  background: var(--card); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 16px; margin-bottom: 16px;
}
.side-card h4 { font-size: 14px; font-weight: 600; margin-bottom: 8px; }
.side-card .rel-item {
  padding: 8px 0; border-bottom: 1px solid var(--border);
  font-size: 13px; cursor: pointer; color: var(--text-secondary);
}
.side-card .rel-item:hover { color: var(--blue); }
.side-card .rel-item:last-child { border-bottom: none; }

/* Collapse */
.collapse-trigger {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14px 0; cursor: pointer; font-weight: 600; font-size: 14px;
  border-bottom: 1px solid var(--border);
}
.collapse-content { display: none; padding: 14px 0; font-size: 13px; color: var(--text-secondary); line-height: 1.8; }
.collapse-content.show { display: block; }

/* AI Layout */
.ai-layout { display: grid; grid-template-columns: 1fr 340px; gap: 0; height: calc(100vh - 133px); }
.ai-chat { display: flex; flex-direction: column; background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; margin: 24px 0 24px 0; }
.ai-chat-header { padding: 16px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
.ai-chat-header .ai-name { font-size: 16px; font-weight: 600; }
.ai-chat-header .ai-badge { font-size: 11px; color: var(--green); background: var(--green-light); padding: 2px 8px; border-radius: 10px; }
.ai-messages { flex: 1; overflow-y: auto; padding: 20px; }
.ai-bubble {
  max-width: 80%; margin-bottom: 14px; padding: 12px 16px; border-radius: 14px;
  font-size: 14px; line-height: 1.6; animation: fadeIn 0.3s;
}
.ai-bubble.user { background: var(--blue); color: #fff; margin-left: auto; border-bottom-right-radius: 4px; }
.ai-bubble.bot { background: var(--bg); margin-right: auto; border-bottom-left-radius: 4px; border: 1px solid var(--border); }
.ai-welcome { text-align: center; color: var(--text-secondary); padding: 60px 20px; }
.ai-welcome > div:first-child { font-size: 56px; margin-bottom: 16px; }
.ai-disclaimer { font-size: 11px; color: #94A3B8; margin-top: 8px; }
.ai-input-area { padding: 12px 20px; border-top: 1px solid var(--border); display: flex; gap: 10px; align-items: center; }
.ai-input-area textarea {
  flex: 1; border: 1px solid var(--border); border-radius: var(--radius);
  padding: 10px 14px; font-size: 14px; outline: none; resize: none; height: 44px;
  font-family: inherit; line-height: 1.5;
}
.ai-input-area textarea:focus { border-color: var(--blue); }
.send-btn {
  width: 44px; height: 44px; border-radius: 50%; background: var(--blue);
  border: none; color: #fff; font-size: 20px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
}
.send-btn:hover { background: var(--blue-dark); }
.ai-sidebar { padding: 24px 0 24px 24px; }

/* Tools */
.tool-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
.tool-card-lg {
  background: var(--card); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 24px; cursor: pointer;
  transition: all 0.2s; display: flex; gap: 16px; align-items: flex-start;
}
.tool-card-lg:hover { box-shadow: var(--shadow-md); border-color: var(--blue); transform: translateY(-1px); }
.tool-card-lg .t-icon { font-size: 40px; flex-shrink: 0; }
.tool-card-lg .t-title { font-size: 16px; font-weight: 600; margin-bottom: 4px; }
.tool-card-lg .t-desc { font-size: 13px; color: var(--text-secondary); }

.hotline-banner {
  background: var(--red-light); border: 1px solid #FCA5A5;
  border-radius: var(--radius); padding: 20px; text-align: center; margin-top: 24px;
}
.hotline-banner .hl-label { font-size: 14px; color: var(--red); font-weight: 600; }
.hotline-banner .hl-number { font-size: 32px; font-weight: 800; color: var(--red); letter-spacing: 4px; margin: 4px 0; }
.hotline-banner .hl-note { font-size: 12px; color: #B91C1C; }

/* Quiz */
.quiz-option {
  padding: 14px; border: 1px solid var(--border); border-radius: var(--radius);
  background: var(--card); cursor: pointer; text-align: left; font-size: 14px;
  margin-bottom: 8px; transition: all 0.15s;
}
.quiz-option:hover { border-color: var(--blue); }
.quiz-option.correct { background: var(--green-light) !important; border-color: var(--green) !important; color: #166534 !important; }
.quiz-option.wrong { background: var(--red-light) !important; border-color: var(--red) !important; color: #991B1B !important; }

/* Article detail */
.article-card {
  background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px;
}
.article-number { font-size: 24px; font-weight: 700; color: var(--blue); margin-bottom: 8px; }
.article-original { font-size: 15px; line-height: 1.9; color: var(--text); margin-bottom: 16px; padding: 16px; background: var(--bg); border-radius: var(--radius-sm); border-left: 4px solid var(--blue); }
.article-plain { font-size: 15px; line-height: 1.8; color: var(--text); padding: 16px; background: var(--blue-light); border-radius: var(--radius-sm); }

/* Elders mode */
body.elders-mode { font-size: 18px; }
body.elders-mode .card { padding: 24px; }
body.elders-mode .sidebar { width: 280px; }
body.elders-mode .main-content { margin-left: 280px; }

/* Floating action buttons */
.fab-top,.fab-hotline{
  position:fixed;right:20px;z-index:200;
  width:48px;height:48px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:20px;text-decoration:none;box-shadow:0 4px 16px rgba(0,0,0,.15);
  transition:all .2s;cursor:pointer;
}
.fab-top{bottom:140px;background:#fff;color:var(--blue);border:1px solid var(--border);display:none}
.fab-hotline{bottom:80px;background:var(--red);color:#fff;font-size:22px}
.fab-top:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.2)}
.fab-hotline:hover{transform:translateY(-2px) scale(1.05);box-shadow:0 6px 20px rgba(220,38,38,.4)}

/* Page fade */
.page{opacity:0;transition:opacity .2s ease}

/* Animations */
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

/* Mobile */
@media (max-width: 768px) {
  .sidebar { width: 60px; }
  .sidebar .logo-text, .sidebar .logo-sub, .sidebar .nav-link span:not(.nav-icon),
  .sidebar .nav-section, .sidebar .nav-badge, .sidebar-footer span { display: none; }
  .sidebar-logo { justify-content: center; padding: 16px 0; }
  .nav-link { justify-content: center; padding: 12px 0; }
  .main-content { margin-left: 60px; }
  .grid-2, .grid-3, .grid-4, .value-cards { grid-template-columns: 1fr; }
  .detail-grid, .ai-layout { grid-template-columns: 1fr; }
  .ai-sidebar { display: none; }
  .hero { padding: 24px; }
  .hero h1 { font-size: 22px; }
  .hero-stats { gap: 16px; }
  .tool-grid { grid-template-columns: 1fr; }
}

/* ══════════════════════════════════════════ */
/*  移动端全面适配 (iPhone SE ~ Pro Max)     */
/* ══════════════════════════════════════════ */
@media (max-width: 768px) {
  /* Sidebar → 底部Tab */
  .sidebar {
    width: 100%; height: auto; position: fixed; bottom: 0; top: auto; left: 0; right: 0;
    flex-direction: row; z-index: 300; border-right: none; border-top: 1px solid var(--border);
    box-shadow: 0 -2px 8px rgba(0,0,0,0.05); padding: 0;
  }
  .sidebar-logo, .sidebar-footer, .nav-section { display: none !important; }
  .sidebar-nav { display: flex; flex-direction: row; justify-content: space-around; padding: 0; overflow: visible; }
  .nav-link {
    flex-direction: column; align-items: center; justify-content: center;
    padding: 6px 0; font-size: 10px; gap: 2px; border-left: none; border-top: 2px solid transparent;
    width: auto; min-width: 50px;
  }
  .nav-link.active { border-left-color: transparent; border-top-color: var(--blue); background: transparent; }
  .nav-link .nav-icon { font-size: 20px; }
  .nav-link .nav-badge { display: none; }

  /* Main content */
  .main-content { margin-left: 0; padding-bottom: 60px; }
  .top-bar { display: none; } /* Hide top search bar on mobile */
  .page { padding: 12px; }
  .page.active { padding-bottom: 80px; }

  /* Hero */
  .hero { padding: 24px 16px; border-radius: 16px; margin-bottom: 16px; }
  .hero h1 { font-size: 22px; }
  .hero p { font-size: 13px; }
  .hero-stats { gap: 16px; justify-content: center; flex-wrap: wrap; }
  .hero-stat .num { font-size: 18px; }
  .hero-stat .label { font-size: 10px; }
  .hero-search { max-width: 100%; }

  /* Grids → single column */
  .grid-2, .grid-3, .grid-4, .value-cards { grid-template-columns: 1fr; gap: 10px; }
  .category-grid { grid-template-columns: repeat(4, 1fr); gap: 6px; }

  /* Cards */
  .card { padding: 14px; }
  .scene-card { padding: 14px; }
  .scene-card .s-title { font-size: 14px; }
  .scene-card .s-conclusion { font-size: 12px; }
  .s-desc { font-size: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  /* AI entry */
  .ai-card { padding: 16px; }
  .ai-card .ai-header { font-size: 28px; margin-bottom: 8px; }
  .ai-card .ai-header .ai-title { font-size: 16px; }
  .ai-example { font-size: 11px; padding: 4px 10px; }

  /* Scene detail */
  .detail-grid { grid-template-columns: 1fr; gap: 16px; }
  .detail-sidebar { display: none; }
  .scene-header h1 { font-size: 20px; }
  .conclusion-box { font-size: 14px; padding: 14px; }
  .step-list li { font-size: 13px; }

  /* AI layout */
  .ai-layout { grid-template-columns: 1fr; height: calc(100vh - 140px); }
  .ai-sidebar { display: none; }
  .ai-chat { margin: 12px; border-radius: 16px; }
  .ai-messages { padding: 12px; }
  .ai-bubble { max-width: 90%; font-size: 13px; }
  .ai-input-area { padding: 10px 12px; }
  .ai-input-area textarea { font-size: 13px; height: 40px; }

  /* Article detail */
  .article-card { padding: 16px; margin-bottom: 60px; }
  .article-number { font-size: 20px; }
  .article-original, .article-plain { font-size: 13px; padding: 12px; }

  /* Values map */
  .value-cards { grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .value-card { padding: 14px 8px; }
  .value-card .v-icon { font-size: 24px; }
  .value-card .v-name { font-size: 13px; }

  /* Tools */
  .tool-grid { grid-template-columns: 1fr; }
  .tool-card-lg { padding: 16px; }

  /* Quiz */
  .quiz-option { font-size: 13px; padding: 10px; }

  /* Floating buttons adjust */
  .fab-top { bottom: 100px; right: 12px; width: 40px; height: 40px; font-size: 16px; }
  .fab-hotline { bottom: 60px; right: 12px; width: 44px; height: 44px; font-size: 18px; }

  /* Page title */
  .page-title-area h1 { font-size: 20px; }
  .back-link { margin-bottom: 12px; }
  .back-link a { font-size: 13px; }

  /* Hotline banner */
  .hotline-banner { padding: 14px; margin-top: 14px; }
  .hotline-banner .hl-number { font-size: 24px; }

  /* Section header */
  .section-header h2 { font-size: 15px; }
  .section-title { font-size: 14px; margin: 14px 0 10px; }

  /* Category grid in home */
  .home-quick { grid-template-columns: 1fr; }
  .cat-item { font-size: 11px; padding: 10px 4px; }
  .category-card { padding: 14px; }

  /* Book list */
  .card-title { font-size: 14px; }

  /* Tool mini */
  .tool-mini { padding: 18px 12px; }
  .tool-mini .t-icon { font-size: 28px; }
  .tool-mini .t-label { font-size: 12px; }

  /* Value detail page */
  #valueDetail > div:first-child { flex-direction: column; text-align: center; padding: 16px; }
  #valueDetail h1 { font-size: 22px; }

  /* Warning box */
  .warning-box { font-size: 12px; padding: 10px; }
}

/* Extra small screens */
@media (max-width: 380px) {
  .hero { padding: 20px 12px; }
  .hero h1 { font-size: 19px; }
  .page { padding: 10px; }
  .value-cards { grid-template-columns: repeat(2, 1fr); }
}

/* Mobile search bar */
.mobile-search { display: none; }
@media (max-width: 768px) { .mobile-search { display: flex; } }
@media (min-width: 769px) { .mobile-search { display: none !important; } }

